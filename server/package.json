{
  "name": "cc-ninja-server",
  "version": "0.2.0",
  "private": true,
  "description": "Local HTTP bridge that receives transcript POSTs from the claude-for-chrome extension and writes memodef:Transcript envelope + sibling .body.md to a configured git repo.",
  "main": "out/index.js",
  "bin": {
    "cc-ninja-server": "out/index.js"
  },
  "scripts": {
    "sync-core": "node -e \"const fs=require('fs');fs.rmSync('src/core',{recursive:true,force:true});fs.cpSync('../core/src','src/core',{recursive:true,force:true})\"",
    "build": "npm run sync-core && tsc -p ./",
    "start": "node out/index.js",
    "dev": "npm run build && npm start"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
